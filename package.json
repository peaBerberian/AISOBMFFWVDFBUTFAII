{
  "name": "aisobmffwvdfbutfaii",
  "version": "2.0.0",
  "description": "A browser-based MP4 box inspector and ISOBMFF visualizer for fragmented MP4, DASH, and Smooth Streaming metadata.",
  "main": "build/aisobmffwvdfbutfaii.js",
  "scripts": {
    "build": "node scripts/build.mjs",
    "check": "npm run lint && npm run typecheck",
    "format": "biome format --write .",
    "lint": "biome check .",
    "min": "AISOBMFFWVDFBUTFAII_MINIFY=true node scripts/build.mjs",
    "typecheck": "tsc -p tsconfig.json",
    "watch": "node scripts/build.mjs --watch"
  },
  "author": "peaberberian",
  "license": "UNLICENSED",
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "esbuild": "^0.28.0",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "isobmff-inspector": "^0.4.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/peaBerberian/AISOBMFFWVDFBUTFAII.git"
  },
  "keywords": [
    "isobmff",
    "mp4",
    "mp4-inspector",
    "mp4-parser",
    "mp4-boxes",
    "parser",
    "visualizer",
    "fragmented-mp4",
    "dash",
    "video-streaming"
  ],
  "bugs": {
    "url": "https://github.com/peaBerberian/AISOBMFFWVDFBUTFAII/issues"
  },
  "homepage": "https://peaberberian.github.io/AISOBMFFWVDFBUTFAII/"
}
