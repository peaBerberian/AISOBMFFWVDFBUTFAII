{
  "name": "aisobmffwvdfbutfaii",
  "version": "1.1.1",
  "description": "An ISOBMFF web visualizer done for better understanding the format and its intricacies.",
  "main": "build/aisobmffwvdfbutfaii.js",
  "scripts": {
    "build": "node scripts/build.mjs",
    "check": "npm run lint && npm run typecheck",
    "format": "biome format --write .",
    "lint": "biome check .",
    "min": "AISOBMFFWVDFBUTFAII_MINIFY=true node scripts/build.mjs",
    "typecheck": "tsc -p tsconfig.json",
    "watch": "node scripts/build.mjs --watch"
  },
  "author": "peaberberian",
  "license": "UNLICENSED",
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "esbuild": "^0.28.0",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "isobmff-inspector": "0.2.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/peaBerberian/AISOBMFFWVDFBUTFAII.git"
  },
  "keywords": [
    "isobmff",
    "parser",
    "visualizer",
    "mp4"
  ],
  "bugs": {
    "url": "https://github.com/peaBerberian/AISOBMFFWVDFBUTFAII/issues"
  },
  "homepage": "https://github.com/peaBerberian/AISOBMFFWVDFBUTFAII#readme"
}
